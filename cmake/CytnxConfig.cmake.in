@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Boost CONFIG REQUIRED)

# Keep native Windows installs independent of the checkout/Pixi environment
# that produced them. The build target uses its resolved LAPACK/ARPACK paths,
# while the installed target resolves those libraries in the consumer's active
# toolchain environment.
if(WIN32 AND NOT @BACKEND_TORCH@)
  if(DEFINED BLA_VENDOR)
    set(_cytnx_had_bla_vendor TRUE)
    set(_cytnx_saved_bla_vendor "${BLA_VENDOR}")
  else()
    set(_cytnx_had_bla_vendor FALSE)
  endif()
  set(BLA_VENDOR "@BLA_VENDOR@")
  find_dependency(LAPACK REQUIRED)
  if(_cytnx_had_bla_vendor)
    set(BLA_VENDOR "${_cytnx_saved_bla_vendor}")
  else()
    unset(BLA_VENDOR)
  endif()
  unset(_cytnx_had_bla_vendor)
  unset(_cytnx_saved_bla_vendor)

  find_library(_cytnx_arpack_library NAMES arpack REQUIRED)
endif()

# Conditional re-find of build-time PUBLIC imported-target deps. The @VAR@
# tokens are expanded to the build-time value of each option when this package
# configuration is emitted.
if(@USE_CUDA@)
  find_dependency(CUDAToolkit REQUIRED)
endif()

if(@USE_HPTT@)
  # libcytnx is a STATIC archive; libhptt.a (which uses OpenMP internally)
  # gets pulled in by reference, so the consumer's final executable link
  # needs OpenMP to resolve libhptt's `__kmpc_*` / `omp_*` symbols. See
  # commit 5733a441 ("Propagate `-fopenmp` linking flag when using HPTT").
  find_dependency(OpenMP REQUIRED)
endif()

if(@BACKEND_TORCH@)
  find_dependency(Torch REQUIRED)
endif()

if(@USE_CUTENSOR@ OR @USE_CUQUANTUM@)
  set(_cytnx_saved_module_path "${CMAKE_MODULE_PATH}")
  list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
  if(@USE_CUTENSOR@)
    find_dependency(CUTENSOR REQUIRED)
  endif()
  if(@USE_CUQUANTUM@)
    find_dependency(CUQUANTUM REQUIRED)
  endif()
  set(CMAKE_MODULE_PATH "${_cytnx_saved_module_path}")
  unset(_cytnx_saved_module_path)
endif()

if(NOT TARGET Cytnx::cytnx)
    include("${CMAKE_CURRENT_LIST_DIR}/CytnxTargets.cmake")
endif()

if(WIN32 AND NOT @BACKEND_TORCH@)
  set_property(TARGET Cytnx::cytnx APPEND PROPERTY
    INTERFACE_LINK_LIBRARIES LAPACK::LAPACK "${_cytnx_arpack_library}")
endif()

if(@USE_CUDA@)
  # cytnx was built with UNI_GPU (applied PUBLIC), so its public header Type.hpp
  # includes <cuda/std/complex>. CUDA 12+/13 relocate that header under the
  # toolkit's cccl/ subdir, which is in no CUDA:: imported target's INTERFACE.
  # The build tree added the dir only through $<BUILD_INTERFACE:>, so the
  # exported target carries no cccl path. Re-detect it against the consumer's own
  # CUDAToolkit (found above) and append it to the imported target's interface
  # includes — this stays relocatable because the path comes from the consumer's
  # toolkit, not the build machine. Detection is shared with the in-tree build.
  include("${CMAKE_CURRENT_LIST_DIR}/CytnxDetectCCCL.cmake")
  cytnx_detect_cccl_include_dir(_cytnx_cccl_dir)
  if(_cytnx_cccl_dir)
    set_property(TARGET Cytnx::cytnx APPEND PROPERTY
      INTERFACE_INCLUDE_DIRECTORIES "${_cytnx_cccl_dir}")
  endif()
  if(NOT TARGET CUDA::cudadevrt)
    find_library(_cytnx_cudadevrt_library
      NAMES cudadevrt
      HINTS "${CUDAToolkit_LIBRARY_DIR}" "${CUDAToolkit_ROOT}"
      PATH_SUFFIXES lib/x64 lib64 lib
    )
    if(NOT _cytnx_cudadevrt_library)
      message(FATAL_ERROR "Cytnx requires the CUDA device-runtime library (cudadevrt)")
    endif()
    set_property(TARGET Cytnx::cytnx APPEND PROPERTY
      INTERFACE_LINK_LIBRARIES "${_cytnx_cudadevrt_library}")
    unset(_cytnx_cudadevrt_library CACHE)
  endif()
endif()

check_required_components(Cytnx)
